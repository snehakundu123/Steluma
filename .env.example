# =====================================================
# STELUMA — Environment Variables
# Copy to .env and fill in values
# =====================================================

# --- Database ---
DATABASE_URL="postgresql://steluma:steluma@localhost:5432/steluma"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- JWT ---
JWT_SECRET="change-me-to-a-long-random-secret-min-64-chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"
# Separate secret for QR code signing (recommended; falls back to JWT_SECRET if not set)
QR_SIGNING_SECRET="change-me-to-another-long-random-secret-min-64-chars"

# --- Stellar ---
STELLAR_NETWORK="testnet"
STELLAR_HORIZON_URL="https://horizon-testnet.stellar.org"
STELLAR_RPC_URL="https://soroban-testnet.stellar.org"
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_ADMIN_SECRET="S..."   # Backend signing keypair — NEVER commit real value

# --- Contract IDs (fill after deployment) ---
EVENT_FACTORY_CONTRACT_ID=""
TICKET_NFT_CONTRACT_ID=""
ATTENDANCE_BADGE_CONTRACT_ID=""
STAKING_CONTRACT_ID=""
MARKETPLACE_CONTRACT_ID=""

# --- IPFS / Pinata ---
PINATA_API_KEY=""
PINATA_API_SECRET=""
PINATA_JWT=""
IPFS_GATEWAY="https://gateway.pinata.cloud/ipfs"

# --- API ---
API_PORT=4000
API_HOST="0.0.0.0"
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"

# --- Frontend (NEXT_PUBLIC_*) ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_STELLAR_NETWORK="testnet"
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
