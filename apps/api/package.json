{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:generate": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/multipart": "^9.0.2",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/swagger": "^9.5.0",
    "@pinata/sdk": "^2.1.0",
    "@prisma/client": "^6.1.0",
    "@stellar/stellar-sdk": "^13.1.0",
    "@steluma/types": "workspace:*",
    "bullmq": "^5.14.0",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "tweetnacl": "^1.0.3",
    "uuid": "^11.0.3",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
