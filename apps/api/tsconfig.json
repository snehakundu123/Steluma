{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "outDir": "dist",
    "composite": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "@steluma/types": ["../../packages/types/src/index.ts"]
    },
    "types": ["vitest/globals", "node"]
  },
  "include": ["src", "../../packages/types/src"],
  "exclude": ["node_modules", "dist"]
}
